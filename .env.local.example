DATABASE_URL=postgresql://user:password@host:5432/dbname
# Same signing key as the Host's JWT_SECRET (organize-me repo) - ha-dashboard only verifies,
# never issues, so this must match exactly in every shared environment.
JWT_SECRET=change-me-to-the-same-value-as-the-hosts-jwt-secret

# No ENCRYPTION_KEY here yet - no code reads it until a later slice actually stores a third-party
# credential (see docs/features/ha-dashboard/WBS/slice-1-repo-and-infra-setup.md's Delivered
# section for why the shared deploy SA's secretAccessor grant is confirmed ahead of that need).
