DATABASE_URL=postgresql://user:password@host:5432/dbname
# Same signing key as the Host's JWT_SECRET (organize-me repo) - ha-dashboard only verifies,
# never issues, so this must match exactly in every shared environment.
JWT_SECRET=change-me-to-the-same-value-as-the-hosts-jwt-secret

# Same shared key as the Host's/event-creator's ENCRYPTION_KEY (Secret Manager `encryption-key-
# prod` in real environments, no QA counterpart) - encrypts the stored HA long-lived access token
# at rest (app.core.security.CredentialCipher, Slice 3). Generate a throwaway one for local dev
# with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-to-a-generated-fernet-key
